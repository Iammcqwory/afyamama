rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'displayName']) &&
             data.keys().size() >= 2 && data.keys().size() <= 5 &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 100;
    }

    function isValidBaby(data) {
      return data.keys().hasAll(['ownerId', 'name', 'birthDate']) &&
             data.keys().size() >= 3 && data.keys().size() <= 6 &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.birthDate is string;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['babyId', 'type', 'timestamp']) &&
             data.keys().size() >= 3 && data.keys().size() <= 6 &&
             data.babyId is string &&
             data.type in ['feeding', 'diaper', 'sleep', 'growth', 'milestone'] &&
             data.timestamp is string;
    }

    function isValidChatSession(data) {
      return data.keys().hasAll(['userId', 'updatedAt']) &&
             data.keys().size() >= 2 && data.keys().size() <= 4 &&
             data.userId == request.auth.uid;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['sessionId', 'text', 'sender', 'timestamp']) &&
             data.keys().size() >= 4 && data.keys().size() <= 6 &&
             data.text is string && data.text.size() <= 10000 &&
             data.sender in ['user', 'ai', 'system'];
             // data.timestamp == request.time; // Removed strict check for more stability with client times if needed, or use serverTimestamp
    }

    function isValidNutritionTask(data) {
      return data.keys().hasAll(['babyId', 'foodName', 'status']) &&
             data.keys().size() >= 3 && data.keys().size() <= 10 &&
             data.foodName is string && data.foodName.size() <= 100 &&
             data.status in ['to_try', 'tried', 'allergy'];
    }

    function isValidVillageMessage(data) {
      return data.keys().hasAll(['villageId', 'userId', 'text', 'timestamp']) &&
             data.keys().size() >= 4 && data.keys().size() <= 8 &&
             data.text is string && data.text.size() <= 1000 &&
             data.userId == request.auth.uid;
    }

    function isValidWellnessLog(data) {
      return data.keys().hasAll(['userId', 'type', 'timestamp']) &&
             data.keys().size() >= 3 && data.keys().size() <= 6 &&
             data.userId == request.auth.uid &&
             data.type in ['mood', 'hydration', 'sleep', 'recovery'];
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                    isValidUser(incoming()) &&
                    incoming().email == existing().email;

      match /villageMemberships/{villageId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /babies/{babyId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidBaby(incoming()) && isValidId(babyId);
      allow update: if isSignedIn() && 
                    existing().ownerId == request.auth.uid &&
                    isValidBaby(incoming()) &&
                    incoming().ownerId == existing().ownerId;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;

      match /logs/{logId} {
        allow get, list: if isSignedIn() && get(/databases/$(database)/documents/babies/$(babyId)).data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && 
                      isValidLog(incoming()) &&
                      get(/databases/$(database)/documents/babies/$(babyId)).data.ownerId == request.auth.uid;
        allow update: if isSignedIn() && 
                      get(/databases/$(database)/documents/babies/$(babyId)).data.ownerId == request.auth.uid &&
                      isValidLog(incoming()) &&
                      incoming().babyId == existing().babyId;
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/babies/$(babyId)).data.ownerId == request.auth.uid;
      }

      match /nutritionLog/{taskId} {
        allow get, list: if isSignedIn() && get(/databases/$(database)/documents/babies/$(babyId)).data.ownerId == request.auth.uid;
        allow create, update, delete: if isSignedIn() && 
                                      get(/databases/$(database)/documents/babies/$(babyId)).data.ownerId == request.auth.uid && 
                                      isValidNutritionTask(incoming());
      }
    }

    match /chatSessions/{sessionId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidChatSession(incoming()) && isValidId(sessionId);
      allow update: if isSignedIn() && 
                    existing().userId == request.auth.uid &&
                    isValidChatSession(incoming()) &&
                    incoming().userId == existing().userId;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      match /messages/{messageId} {
        allow get, list: if isSignedIn() && get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.userId == request.auth.uid;
        allow create: if isSignedIn() && 
                      isValidMessage(incoming()) &&
                      get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.userId == request.auth.uid;
      }
    }

    match /villages/{villageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        // Allow incrementing memberCount
        incoming().diff(existing()).affectedKeys().hasOnly(['memberCount'])
      );
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidVillageMessage(incoming());
      }
    }

    match /wellnessLogs/{logId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidWellnessLog(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidWellnessLog(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
