rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Path Variable Hardening
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return request.auth.token.email_verified == true;
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'displayName']) &&
             data.keys().size() <= 5 &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 100;
    }

    function isValidBaby(data) {
      return data.keys().hasAll(['ownerId', 'name', 'birthDate']) &&
             data.keys().size() <= 6 &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.birthDate is string; // Simplified for draft, should be timestamp if possible but blueprint says string format date-time
    }

    function isValidLog(data) {
      return data.keys().hasAll(['babyId', 'type', 'timestamp']) &&
             data.keys().size() <= 6 &&
             data.babyId is string &&
             data.type in ['feeding', 'diaper', 'sleep', 'growth', 'milestone'] &&
             data.timestamp is string;
    }

    function isValidChatSession(data) {
      return data.keys().hasAll(['userId', 'updatedAt']) &&
             data.keys().size() <= 4 &&
             data.userId == request.auth.uid &&
             data.updatedAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['sessionId', 'text', 'sender', 'timestamp']) &&
             data.keys().size() <= 6 &&
             data.text is string && data.text.size() <= 5000 &&
             data.sender in ['user', 'ai', 'system'] &&
             data.timestamp == request.time;
    }

    // Phase 4: Match Blocks
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                    incoming().email == existing().email;
    }

    match /babies/{babyId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidBaby(incoming()) && isValidId(babyId);
      allow update: if isSignedIn() && existing().ownerId == request.auth.uid &&
                    isValidBaby(incoming()) &&
                    incoming().ownerId == existing().ownerId;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;

      match /logs/{logId} {
        allow get, list: if isSignedIn() && get(/databases/$(database)/documents/babies/$(babyId)).data.ownerId == request.auth.uid;
        allow create: if isSignedIn() && isValidLog(incoming()) &&
                      get(/databases/$(database)/documents/babies/$(babyId)).data.ownerId == request.auth.uid;
        allow update: if isSignedIn() && get(/databases/$(database)/documents/babies/$(babyId)).data.ownerId == request.auth.uid &&
                      isValidLog(incoming()) &&
                      incoming().babyId == existing().babyId;
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/babies/$(babyId)).data.ownerId == request.auth.uid;
      }
    }

    match /chatSessions/{sessionId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidChatSession(incoming()) && isValidId(sessionId);
      allow update: if isSignedIn() && existing().userId == request.auth.uid &&
                    isValidChatSession(incoming()) &&
                    incoming().userId == existing().userId;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      match /messages/{messageId} {
        allow get, list: if isSignedIn() && get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.userId == request.auth.uid;
        allow create: if isSignedIn() && isValidMessage(incoming()) &&
                      get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.userId == request.auth.uid;
      }
    }
  }
}
